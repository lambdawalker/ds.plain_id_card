.title-section {
    display: flex;
    flex-direction: row;
}

.title-section > div {
    flex: 1;
}

p span {
    font-size: .7em;
}

.middle, .bottom-row {
    font-size: .9em;
    margin-top: 3em;
}

.bottom-row .label {
    font-size: .8em;
    font-weight: bold;
}

h1, h2, h3, h4, h5, h6 {
    text-align: left;
}

.title > * {
    text-align: {{ ["left", "center", "right"] |random }};
}

.data-section {
    display: flex;
    flex-direction: {{ ["column", "column-reverse"] | random }};;
}

.name-holder {
    display: flex;
    align-items: center;
    justify-items: stretch;
    flex-direction: {{ ["row", "row-reverse"] | random }};
}

.name-holder > div {
    flex-grow: 1;
}

{%- set direction = [0,1] | random -%}


.card-body {
    flex-direction: {{ ["row", "row-reverse"][direction] }};
}

.small-photo {
    {{ ["right", "left"][direction] }}: {{ (range(5, 100) | random) }}mm;
}


